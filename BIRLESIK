def sonraki_calisma():
    simdi = datetime.now(ISTANBUL_TZ); bugun = simdi.date()
    for saat in CALISMA_SAATLERI:
        hedef = datetime.combine(bugun, saat, tzinfo=ISTANBUL_TZ)
        if hedef > simdi: return (hedef - simdi).total_seconds(), hedef
    import datetime as dt_mod
    yarin = bugun + dt_mod.timedelta(days=1)
    hedef = datetime.combine(yarin, CALISMA_SAATLERI[0], tzinfo=ISTANBUL_TZ)
    return (hedef - simdi).total_seconds(), hedef

def zamanlayici_dongusu():
    global zamanlayici_aktif
    if not zamanlayici_aktif: return
    if bot_durumu["calisiyor"]:
