                 "çorap","socks","sock","pijama","pyjama","gecelik","bikini","mayo",
                 "swimwear","bandeau","bodice"],
    "spor":     ["spor","sport","sports","gym","yoga","training","atletik",
                 "athletic","running","koşu","fitness"],
}

def _kategori_bul(isim: str) -> str:
    s = isim.lower()
    s = re.sub(r'[^a-zçğışöü\s]', ' ', s)
    for kat, kelimeler in KATEGORI_SOZLUK.items():
        if any(k in s for k in kelimeler):
            return kat
    return "diger"

def _normalize(isim: str) -> str:
    s = isim.lower()
    s = re.sub(r'\b(p\d{6,}|l\d{4,}|n\d{4,}|c\d{4,})\b', '', s)
    s = re.sub(r'[^a-zçğışöü\s]', ' ', s)
    s = re.sub(r'\b\w\b', '', s)
    return ' '.join(s.split())

def benzerlik_skoru(a: str, b: str) -> float:
    na, nb = _normalize(a), _normalize(b)
    if not na or not nb: return 0.0
    return SequenceMatcher(None, na, nb).ratio()

def benzer_urunleri_bul(defacto_urunler, hedef_urunler, esik=0.62):
    ALT_GRUPLAR = {"pantolon", "etek", "elbise"}
    UST_GRUPLAR = {"ust"}
    IZOLE       = {"ayakkabi", "aksesuar", "ic_giyim"}
    eslesler = []
    for du in defacto_urunler:
        d_isim = du.get("isim", ""); d_kat = _kategori_bul(d_isim)
        en_iyi, en_skor = None, 0
        for zu in hedef_urunler:
            z_isim = zu.get("isim", ""); z_kat = _kategori_bul(z_isim)
            if d_kat != z_kat:
                if not (d_kat == "diger" or z_kat == "diger"): continue
            if (d_kat in ALT_GRUPLAR and z_kat in UST_GRUPLAR) or \
               (d_kat in UST_GRUPLAR and z_kat in ALT_GRUPLAR): continue
            if d_kat in IZOLE and z_kat not in {d_kat, "diger"}: continue
            pid_d = re.search(r'[pP](\d{8,})', du.get("link",""))
            pid_z = re.search(r'[pP](\d{8,})', zu.get("link",""))
            if pid_d and pid_z and pid_d.group(1) == pid_z.group(1):
                en_iyi, en_skor = zu, 1.0; break
            skor = benzerlik_skoru(d_isim, z_isim)
            if skor > en_skor: en_skor, en_iyi = skor, zu
        if en_iyi and en_skor >= esik: eslesler.append((du, en_iyi, en_skor))
    return eslesler


