def _ac_galeri(urunler, baslik):
    """Resimli ürün galerisi penceresi aç."""
    modal = ctk.CTkToplevel(root)
    modal.title(baslik)
    modal.geometry("1180x760")
    modal.configure(fg_color="#181b1f")
    modal.attributes("-topmost", True)

    hdr = ctk.CTkFrame(modal, fg_color="#2c3e50", corner_radius=0, height=55)
    hdr.pack(fill="x")
    hdr.pack_propagate(False)
    ctk.CTkLabel(hdr, text=baslik, font=("Segoe UI", 17, "bold"), text_color="white").pack(side="left", padx=20, pady=12)
    ctk.CTkLabel(hdr, text=f"{len(urunler)} ürün", font=("Segoe UI", 12), text_color="#bdc3c7").pack(side="right", padx=20)

    scroll_f = ctk.CTkScrollableFrame(modal, fg_color="transparent")
    scroll_f.pack(fill="both", expand=True, padx=8, pady=8)

    COLS = 4
    for c in range(COLS):
        scroll_f.grid_columnconfigure(c, weight=1)

    for idx, urun in enumerate(urunler[:200]):
        r, c = divmod(idx, COLS)
        card = ctk.CTkFrame(scroll_f, fg_color="#1e272e", corner_radius=10,
                            border_width=1, border_color="#2f3640", width=255, height=270)
        card.grid(row=r, column=c, padx=5, pady=5, sticky="nsew")
        card.grid_propagate(False)

