def _haftalik_degisim() -> str:
    """Bu hafta ile geçen haftanın toplamını karşılaştır."""
    veri = haftalik_yukle()
    if len(veri) < 2:
        return "—"
    anahtarlar = sorted(veri.keys())
    bu_hafta = veri[anahtarlar[-1]]
    gecen_hafta = veri[anahtarlar[-2]]
    if gecen_hafta == 0:
        return "—"
    oran = (bu_hafta - gecen_hafta) / gecen_hafta * 100
    isaret = "+" if oran >= 0 else ""
    return f"{isaret}{oran:.1f}%"


