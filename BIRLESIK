                    try:
                        mod.after(0, lambda lb=lbl, ci=ctk_img: lb.configure(image=ci, text=""))
                    except: pass
                except:
                    try: mod.after(0, lambda lb=lbl: lb.configure(text="🖼️"))
                    except: pass
            threading.Thread(target=_load_img, args=(gorsel, img_lbl, modal), daemon=True).start()

