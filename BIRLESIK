async def scroll_down(page, step=1200, wait=180, max_same=3):
    prev, same, pos = 0, 0, 0
    while True:
        await page.evaluate(f"window.scrollTo(0,{pos})"); await page.wait_for_timeout(wait); pos += step
        h = await page.evaluate("document.body.scrollHeight")
        if h == prev:
            same += 1
            if same >= max_same: break
        else: same, prev = 0, h
    return prev


