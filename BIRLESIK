def _ciz_cizgi_grafik(parent):
    """Haftalık yeni ürün trendi — tk.Canvas ile çiz."""
    W, H = 520, 180
    canvas = tk.Canvas(parent, width=W, height=H, bg="#1e272e", highlightthickness=0)
    canvas.pack(padx=15, pady=(0, 15))

    veri = haftalik_yukle()
    anahtarlar = sorted(veri.keys())[-8:]
    degerler = [veri.get(k, 0) for k in anahtarlar]
    if not degerler or max(degerler) == 0:
        canvas.create_text(W//2, H//2, text="Veri yok — ilk tur tamamlandıktan sonra görünecek",
                           fill="#7f8c8d", font=("Segoe UI", 10))
        return

    PAD_L, PAD_R, PAD_T, PAD_B = 40, 10, 10, 35
    gW = W - PAD_L - PAD_R
    gH = H - PAD_T - PAD_B
    maks = max(degerler) or 1

    # Grid çizgileri
    for i in range(5):
        y = PAD_T + gH - int(gH * i / 4)
        canvas.create_line(PAD_L, y, W - PAD_R, y, fill="#2f3640", width=1)
        canvas.create_text(PAD_L - 4, y, text=str(int(maks * i / 4)),
                           fill="#7f8c8d", font=("Segoe UI", 8), anchor="e")

    # Hafta etiketleri & koordinatlar
    N = len(degerler)
    pts = []
    for i, (k, v) in enumerate(zip(anahtarlar, degerler)):
        x = PAD_L + int(gW * i / max(N - 1, 1))
        y = PAD_T + gH - int(gH * v / maks)
        pts.append((x, y))
        hafta = k.split("-W")[-1] if "-W" in k else k
        canvas.create_text(x, H - PAD_B + 12, text=f"H{hafta}",
                           fill="#7f8c8d", font=("Segoe UI", 8))

    # Dolgu alanı
    if len(pts) >= 2:
        poly = [pts[0][0], PAD_T + gH]
        for x, y in pts:
            poly += [x, y]
        poly += [pts[-1][0], PAD_T + gH]
        canvas.create_polygon(poly, fill="#1a3352", outline="")

    # Çizgi
    for i in range(len(pts) - 1):
        canvas.create_line(pts[i][0], pts[i][1], pts[i+1][0], pts[i+1][1],
                           fill="#e67e22", width=2)

    # Noktalar
    for x, y in pts:
        canvas.create_oval(x-3, y-3, x+3, y+3, fill="#e67e22", outline="#f39c12")


def _ciz_donut_grafik(parent):
    """Marka dağılımı — tk.Canvas ile donut chart çiz."""
    W, H = 300, 180
    canvas = tk.Canvas(parent, width=W, height=H, bg="#1e272e", highlightthickness=0)
    canvas.pack(padx=15, pady=(0, 15))

    # Marka gruplarına göre toplam ürün sayısı
    GRUPLAR = [
        ("Zara", "#e67e22"), ("Defacto", "#e74c3c"), ("MD", "#9b59b6"),
        ("Bershka", "#3498db"), ("Stradivarius", "#2ecc71"), ("Uniqlo", "#1abc9c"),
        ("YSL", "#f1c40f"), ("Aritzia", "#e91e63"), ("Brandy", "#fd79a8"), ("Diğer", "#636e72"),
    ]
    grup_say = {g: 0 for g, _ in GRUPLAR}
    for ad, d in bot_durumu["marka_durumlari"].items():
        s = d.get("urun_sayisi", 0)
        es = False
        for g, _ in GRUPLAR:
            if g.lower() in ad.lower():
                grup_say[g] += s; es = True; break
        if not es:
            grup_say["Diğer"] += s

    toplam = sum(grup_say.values()) or 1
    aktif = [(g, s, c) for (g, c), s in zip(
        {g: c for g, c in GRUPLAR}.items(), grup_say.values()) if s > 0]

    cx, cy, R, r = W // 2 - 30, H // 2, 70, 42
    start = -90.0
    for g, s, c in aktif:
        extent = 360.0 * s / toplam
        canvas.create_arc(cx-R, cy-R, cx+R, cy+R, start=start, extent=extent,
                          fill=c, outline="#1e272e", width=2, style="pieslice")
        canvas.create_oval(cx-r, cy-r, cx+r, cy+r, fill="#1e272e", outline="#1e272e")
        start += extent

    canvas.create_text(cx, cy, text=str(toplam), font=("Segoe UI", 16, "bold"), fill="white")
    canvas.create_text(cx, cy + 16, text="TOPLAM", font=("Segoe UI", 7), fill="#7f8c8d")

    # Lejant
    lx = W - 85
    for i, (g, s, c) in enumerate(aktif[:8]):
        ly = 15 + i * 20
        canvas.create_rectangle(lx, ly, lx+10, ly+10, fill=c, outline="")
        canvas.create_text(lx + 14, ly + 5, text=f"{g} {s}",
                           fill="#bdc3c7", font=("Segoe UI", 8), anchor="w")


