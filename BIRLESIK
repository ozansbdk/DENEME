STRADIVARIUS_JS = r"""(url) => {
    const base = new URL(url).origin;
    const slugToName = h => { try { const s=decodeURIComponent(h.split('/').filter(Boolean).pop()||''); return s.replace(/-(n|c|l)\d+$/,'').replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()); } catch(e){return '';} };
    const R=[], S=new Set();
    const els = [...document.querySelectorAll('a[href],a[data-href]')];
    els.forEach(a => {
        const raw = a.getAttribute('data-href') || a.getAttribute('href') || '';
        if(!raw || raw === '#') return;
        let h = raw.startsWith('http') ? raw : (raw.startsWith('/') ? base + raw : '');
        h = h.split('?')[0];
        if(!h || !h.includes('stradivarius') || S.has(h) || h === url) return;
        if(/\/(n|c|l)\d{3,}$/.test(h.split('/').pop())) return;
        if(/null$/.test(h)) return;
        S.add(h);
        const el = a.closest('li') || a.closest('article') || a.closest('[class*="product"]') || a.closest('[class*="grid-item"]') || a.parentElement;
        let g = '', n = '', p = '';
        if(el){
            for(const img of el.querySelectorAll('img')){
                const src=(img.src||img.getAttribute('data-src')||img.getAttribute('srcset')||'').trim().split(/\s+/)[0];
                const fixed=src.startsWith('//')?'https:'+src:src;
                if(fixed&&!fixed.includes('svg')&&!fixed.includes('logo')&&(fixed.includes('.jpg')||fixed.includes('.webp'))){g=fixed.split('?')[0]+'?w=600';break;}
            }
            for(const ns of['[class*="name"]','[class*="product-name"]','[class*="title"]','h2','h3','h4']){
                const e=el.querySelector(ns); const t=e?e.innerText.trim():'';
                if(t.length>1&&t.length<120){n=t;break;}
            }
            const pe=el.querySelector('[class*="price"],[class*="amount"],[class*="Price"]');
            if(pe) p=pe.innerText.trim().split(String.fromCharCode(10))[0];
        }
        if(!n) n=a.getAttribute('aria-label')||a.getAttribute('title')||a.getAttribute('alt')||slugToName(h)||'Ürün';
        if(n && n.length > 1) R.push({isim:n, fiyat:p, link:h, gorsel:g});
    });
    return R;
}"""

