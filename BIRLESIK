def gemini_sor(prompt: str) -> str:
    """Google Gemini AI'a soru sor."""
    if not GEMINI_API_KEY:
        return "❌ Gemini API key ayarlanmamış."
    try:
        payload = {
            "contents": [{"parts": [{"text": prompt}]}],
            "generationConfig": {"temperature": 0.7, "maxOutputTokens": 2048}
        }
        r = requests.post(GEMINI_URL, json=payload, headers={"Content-Type":"application/json"}, timeout=30)
        if r.status_code == 200:
            data = r.json()
            return data["candidates"][0]["content"]["parts"][0]["text"]
        else:
            return f"❌ Gemini API hatası: HTTP {r.status_code}\n{r.text[:200]}"
    except Exception as e:
        return f"❌ Gemini bağlantı hatası: {e}"


def ai_analiz_yap(sayac, benzerlik_sonuclari, marka_durumlari):
    """Tur sonuçlarını Gemini AI ile analiz et."""
    basarili = sum(1 for v in marka_durumlari.values() if v.get("urun_sayisi",0) > 0)
    hatali = sum(1 for v in marka_durumlari.values() if v.get("hata",""))

    # En çok yeni ürün olan markalar
    en_cok_yeni = sorted(
        [(ad, v.get("yeni",0)) for ad, v in marka_durumlari.items() if v.get("yeni",0) > 0],
        key=lambda x: -x[1]
    )[:10]

    benzerlik_ozet = ""
    if benzerlik_sonuclari:
        acil = sum(1 for s in benzerlik_sonuclari if s["skor"] >= 0.85)
        benzerlik_ozet = f"\n- Toplam {len(benzerlik_sonuclari)} benzerlik eşleşmesi, {acil} tanesi ACİL (>%85)"
        for s in sorted(benzerlik_sonuclari, key=lambda x: -x["skor"])[:5]:
            benzerlik_ozet += f"\n  • Defacto '{s['defacto'][:40]}' ↔ '{s['hedef'][:40]}' (%{int(s['skor']*100)})"

    yeni_str = "\n".join(f"  • {ad}: {say} yeni" for ad, say in en_cok_yeni) if en_cok_yeni else "  Yeni ürün yok"

    prompt = f"""Sen bir moda perakende analisti AI'sın. DeFacto için rakip analizi yapıyorsun.

Tarama Sonuçları:
- Başarılı taranan marka sayısı: {basarili}
- Hatalı: {hatali}
- Kadın yeni: {sayac.get('kadin',0)}, Erkek yeni: {sayac.get('erkek',0)}, Çocuk yeni: {sayac.get('cocuk',0)}
- Defacto yeni: {sayac.get('defacto',0)}

En çok yeni ürün ekleyen markalar:
{yeni_str}

Benzerlik Analizi:{benzerlik_ozet if benzerlik_ozet else ' Benzerlik bulunamadı'}

Lütfen şunları yap:
1. 🔍 Kısa özet (3 satır)
2. 🚨 Acil aksiyon önerileri (benzerlik sonuçlarına göre)
3. 📈 Trend tahmini (hangi kategorilerde hareket var)
4. 💡 DeFacto için stratejik öneriler

Türkçe ve kısa yaz."""

    return gemini_sor(prompt)


def ai_soru_sor_thread(soru, callback):
    """AI'a ayrı thread'de soru sor."""
    def worker():
        cevap = gemini_sor(soru)
        try: root.after(0, lambda: callback(cevap))
        except: pass
    threading.Thread(target=worker, daemon=True).start()


