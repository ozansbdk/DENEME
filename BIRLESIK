def _urun_thumb_kart(parent, urun):
    """Son eklenenler satırı için tek ürün thumbnail kartı."""
    card = ctk.CTkFrame(parent, fg_color="#252d35", corner_radius=10,
                        border_width=1, border_color="#2f3640",
                        width=140, height=200, cursor="hand2")
    card.pack(side="left", padx=6, pady=4)
    card.pack_propagate(False)

    img_lbl = ctk.CTkLabel(card, text="⏳", font=("Segoe UI", 18),
                           fg_color="#1a2129", width=128, height=130,
                           corner_radius=8, cursor="hand2")
    img_lbl.pack(pady=(6, 4), padx=6)

    isim = (urun.get("isim") or "—")[:22]
    ctk.CTkLabel(card, text=isim, font=("Segoe UI", 9, "bold"), text_color="white",
                 wraplength=128).pack(padx=5)
    fiyat = (urun.get("fiyat") or "").strip()[:18]
    if fiyat:
        ctk.CTkLabel(card, text=fiyat, font=("Segoe UI", 9, "bold"),
                     text_color="#f1c40f").pack()

    link = urun.get("link", "")
    gorsel = urun.get("gorsel", "")

    if gorsel and gorsel.startswith("http"):
        def _load(url, lbl):
            try:
                resp = requests.get(url, timeout=6, headers={"User-Agent": "Mozilla/5.0"})
                pil_img = PILImage.open(io.BytesIO(resp.content)).convert("RGB")
                pil_img.thumbnail((128, 130), PILImage.LANCZOS)
                ctk_img = ctk.CTkImage(light_image=pil_img, dark_image=pil_img,
                                       size=(pil_img.width, pil_img.height))
                _detay_img_refs.append(ctk_img)
                try: root.after(0, lambda: lbl.configure(image=ctk_img, text=""))
                except: pass
            except:
                try: root.after(0, lambda: lbl.configure(text="🖼️"))
                except: pass
        threading.Thread(target=_load, args=(gorsel, img_lbl), daemon=True).start()

    if link:
        for w in (card, img_lbl):
            w.bind("<Button-1>", lambda e, l=link: webbrowser.open(l))


