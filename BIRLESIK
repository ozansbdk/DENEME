def haftalik_kaydet(yeni_sayisi: int):
    """Bu haftanın verisi güncelle."""
    veri = haftalik_yukle()
    hafta_no = datetime.now().isocalendar()[1]
    yil = datetime.now().year
    anahtar = f"{yil}-W{hafta_no:02d}"
    veri[anahtar] = veri.get(anahtar, 0) + yeni_sayisi
    # Son 16 haftayı sakla
    anahtarlar = sorted(veri.keys())[-16:]
    veri = {k: veri[k] for k in anahtarlar}
    try:
        with open(HAFTALIK_DOSYA, "w", encoding="utf-8") as f:
            json.dump(veri, f, ensure_ascii=False, indent=2)
    except: pass

