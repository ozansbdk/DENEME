    const slugToName = h => { try { const slug=decodeURIComponent(h.split('/').filter(Boolean).pop()||''); return slug.replace(/\.html.*/,'').replace(/-l\d+$/,'').replace(/-/g,' ').replace(/\b\w/g,c=>c.toUpperCase()); } catch(e){return '';} };
    const R=[],S=new Set(),base=new URL(url).origin;

    // Attempt 1: Extract from Next.js __NEXT_DATA__ (Zara SSR)
    try {
        const nd=document.getElementById('__NEXT_DATA__');
        if(nd){
            const walk=(obj,d)=>{
                if(!obj||typeof obj!=='object'||d>12)return;
                if(Array.isArray(obj)){obj.forEach(i=>walk(i,d+1));return;}
                if(obj.id&&obj.name&&typeof obj.name==='string'&&obj.name.length>1&&(obj.seo||obj.xmedia||obj.prices)){
                    let link='',g='',price='';
                    if(obj.seo?.url) link=obj.seo.url.startsWith('http')?obj.seo.url:base+obj.seo.url;
                    else if(obj.seo?.keyword) link=base+'/'+url.split('/').filter(Boolean)[1]+'/'+url.split('/').filter(Boolean)[2]+'/'+obj.seo.keyword+'.html';
                    if(!link||S.has(link)){Object.values(obj).forEach(v=>walk(v,d+1));return;}
                    S.add(link);
                    const media=obj.xmedia||obj.images||[];
                    if(media.length){const m=media[0];const raw=m.url||m.path||'';g=raw?(raw.startsWith('//')?'https:'+raw:raw)+'?ts=1&w=600&f=auto':'';}
                    if(obj.prices?.length){const p=obj.prices[0];price=(p.formattedAmount||String(p.amount||'')).replace(/\n.*/,'');}
                    R.push({isim:obj.name,fiyat:price,link:link,gorsel:g});
                }
                Object.values(obj).forEach(v=>walk(v,d+1));
            };
            walk(JSON.parse(nd.textContent)?.props?.pageProps,0);
            if(R.length>0)return R;
        }
    } catch(e){}

    // Attempt 2: DOM scraping with broader selectors
    let items=document.querySelectorAll('[data-productid],li[class*="product-grid-product"],li[class*="product-grid"],article[class*="product"]');
    if(!items.length) items=document.querySelectorAll('li[class*="product"],li[class*="item"],article[class*="item"]');
    if(!items.length) items=document.querySelectorAll('li,article');
    items.forEach(el=>{
        const a=el.querySelector('a[href*=".html"],a[href*="/p/"]')||el.querySelector('a[href]'); if(!a) return;
        const h=a.href; if(!h.includes(base)||h===url||S.has(h)) return;
        if(/\/(l|n)\d{3,}\.html/.test(h)||/[?#]/.test(h.replace(url,''))&&h===url) return;
        if(/-(l|n)\d{3,}$/.test(h)) return;
        S.add(h);
        let g=''; for(const img of el.querySelectorAll('img')){ const raw=img.src||img.dataset?.src||img.getAttribute('data-src')||img.getAttribute('srcset')||''; const src=raw.trim().split(/\s+/)[0]; const fixed=src.startsWith('//')?'https:'+src:src; if(fixed&&(fixed.includes('.jpg')||fixed.includes('.webp'))&&!fixed.includes('logo')){g=fixed.split('?')[0]+'?ts=1&w=600&f=auto';break;} }
        let n=''; for(const ns of['[class*="name"]','[class*="product-name"]','[aria-label]','h2','h3','h4']){ const e=el.querySelector(ns); const t=e?(e.getAttribute('aria-label')||e.innerText||'').trim():''; if(t.length>1&&t.length<120){n=t;break;} }
        if(!n) n=a.getAttribute('aria-label')||a.getAttribute('title')||slugToName(h)||'Ürün';
        const p=el.querySelector('[class*="price__amount"],[class*="money-amount"],[class*="price"],[class*="Price"]');
        R.push({isim:n,fiyat:p?p.innerText.trim().split(String.fromCharCode(10))[0]:'',link:h,gorsel:g});
    }); return R;
}"""

