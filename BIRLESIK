OG_IMAGE_JS = """() => { const m=document.querySelector('meta[property="og:image"]'); return m?m.getAttribute('content'):''; }"""

async def gorsel_zenginlestir(browser, urunler, max_enrich=10):
    eksik = [u for u in urunler if not u.get("gorsel")][:max_enrich]
    if not eksik: return urunler
    async def og_cek(u):
        ctx = await browser.new_context(viewport={"width":1280,"height":800},
            user_agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36")
        page = await ctx.new_page()
        try:
            await page.goto(u["link"], wait_until="domcontentloaded", timeout=20000)
            og = await page.evaluate(OG_IMAGE_JS)
            if og and og.startswith("http"): u["gorsel"] = og
        except: pass
        finally: await ctx.close()
    await asyncio.gather(*[og_cek(u) for u in eksik])
    return urunler


