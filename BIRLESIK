            def _load_img(url, lbl, mod):
                try:
                    resp = requests.get(url, timeout=7, headers={"User-Agent": "Mozilla/5.0"})
                    pil_img = PILImage.open(io.BytesIO(resp.content)).convert("RGB")
                    pil_img.thumbnail((243, 150), PILImage.LANCZOS)
                    ctk_img = ctk.CTkImage(light_image=pil_img, dark_image=pil_img,
