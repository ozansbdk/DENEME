def ciz_teknik_analiz():
    global tech_canvas_widget
    sembol = tech_sembol_var.get()
    
    if sembol not in gecmis_veriler:
        messagebox.showwarning("Uyarı", "Seçilen varlık için yeterli veri yok.")
        return

    if tech_canvas_widget:
        tech_canvas_widget.destroy()

    fig, ax = plt.subplots(figsize=(10, 5), facecolor='#181b1f')
    fig.patch.set_facecolor('#181b1f')
    ax.set_facecolor('#181b1f')

    data = gecmis_veriler[sembol]
    tarihler = [datetime.datetime.strptime(t, '%Y-%m-%d') for t in data["tarihler"]]
    degerler = data["degerler"]

    # Pandas ile veriyi işle
    df = pd.DataFrame({"Fiyat": degerler}, index=tarihler)

    # Ana fiyat çizgisi
    ax.plot(df.index, df["Fiyat"], color="#3498db", label=f"{sembol} Fiyatı", linewidth=2)

    # SMA 20 (20 Günlük Hareketli Ortalama)
    if sma20_var.get():
        df["SMA20"] = df["Fiyat"].rolling(window=20).mean()
        ax.plot(df.index, df["SMA20"], color="#f1c40f", label="SMA 20", linewidth=1.5, linestyle="--")

    # SMA 50 (50 Günlük Hareketli Ortalama)
    if sma50_var.get():
        df["SMA50"] = df["Fiyat"].rolling(window=50).mean()
        ax.plot(df.index, df["SMA50"], color="#e74c3c", label="SMA 50", linewidth=1.5, linestyle="-.")
        
    # Bollinger Bantları
    if bollinger_var.get():
        if "SMA20" not in df:
            df["SMA20"] = df["Fiyat"].rolling(window=20).mean()
        df["STD20"] = df["Fiyat"].rolling(window=20).std()
        df["Upper"] = df["SMA20"] + (df["STD20"] * 2)
        df["Lower"] = df["SMA20"] - (df["STD20"] * 2)
        
        ax.plot(df.index, df["Upper"], color="#9b59b6", label="Bollinger Üst", linewidth=1, alpha=0.6)
        ax.plot(df.index, df["Lower"], color="#9b59b6", label="Bollinger Alt", linewidth=1, alpha=0.6)
        ax.fill_between(df.index, df["Lower"], df["Upper"], color="#9b59b6", alpha=0.1)

    ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %y'))
    fig.autofmt_xdate()

    ax.tick_params(colors='white')
    for spine in ax.spines.values(): spine.set_color('#3d3d3d')
    ax.grid(color='#3d3d3d', linestyle='--', linewidth=0.5, alpha=0.7)

    plt.title(f"{sembol} Teknik Göstergeler", color="white")
    fig.legend(loc="upper left", bbox_to_anchor=(0.1, 0.9), facecolor='#1e272e', edgecolor='none', labelcolor='white')

    plt.tight_layout()
    canvas = FigureCanvasTkAgg(fig, master=tech_chart_frame)
    canvas.draw()
    tech_canvas_widget = canvas.get_tk_widget()
    tech_canvas_widget.pack(fill="both", expand=True)

