# --- GEMINI API ENTEGRASYONU ---
def gemini_istek_gonder(prompt, arama_kullan=False):
    if not GEMINI_API_KEY or GEMINI_API_KEY == "BURAYA_API_ANAHTARINIZI_GIRIN":
        return None
        
    url = f"{GEMINI_API_URL}?key={GEMINI_API_KEY}"
    payload = {"contents": [{"parts": [{"text": prompt}]}]}
    if arama_kullan:
        payload["tools"] = [{"google_search": {}}]
        
    try:
        response = requests.post(url, headers={'Content-Type': 'application/json'}, json=payload, timeout=40)
        if response.status_code == 200:
            return response.json()["candidates"][0]["content"]["parts"][0]["text"]
        else:
            print(f"Gemini API Hata Kodu: {response.status_code}")
            return None
    except Exception as e:
        print(f"Gemini API Hatası: {e}")
        return None

def gemini_ile_veri_tamamla():
    prompt = """Türkiye ve global piyasalar için aşağıdaki güncel ekonomik verileri bul ve SADECE JSON formatında döndür:
    {"Aktifhv": {"deger": 0.0, "onceki": 0.0, "birim": "%"}, "AOFM": {"deger": 0.0, "onceki": 0.0, "birim": "%"}, "Tüfe -Aylık": {"deger": 0.0, "onceki": 0.0, "birim": "%"}, "Üfe -Aylık": {"deger": 0.0, "onceki": 0.0, "birim": "%"}, "Mazot tl": {"deger": 0.0, "onceki": 0.0, "birim": "TL"}, "Benzin tl": {"deger": 0.0, "onceki": 0.0, "birim": "TL"}, "STTRFPHR": {"deger": 0.0, "onceki": 0.0, "birim": "$"}, "BCOM": {"deger": 0.0, "onceki": 0.0, "birim": "Puan"}}
    Sadece JSON çıktısı ver."""
    
    text = gemini_istek_gonder(prompt, arama_kullan=True)
    if text:
        json_match = re.search(r'\{.*\}', text, re.DOTALL)
        if json_match:
            return json.loads(json_match.group(0))
    return None

