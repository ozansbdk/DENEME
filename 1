def etki_belirle(baslik):
    b = baslik.lower()
    if any(k in b for k in ["yükseldi", "arttı", "rekor", "kâr", "büyüdü", "olumlu", "kazandı", "uçuşa"]): return "Pozitif"
    elif any(k in b for k in ["düştü", "azaldı", "zarar", "kriz", "çakıldı", "geriledi", "kaybetti", "şok", "düşüş"]): return "Negatif"
    return "Nötr"

def getir_haber_akisi():
    global haber_akisi_cache
    if haber_akisi_cache:
        goster_haberler()
        return
    for w in news_container.winfo_children(): w.destroy()
    ctk.CTkLabel(news_container, text="📰 Gerçek zamanlı güncel piyasa haberleri çekiliyor...", font=("Segoe UI", 14)).pack(pady=50)

    def haber_cek():
        global haber_akisi_cache
        yeni_haberler = []
        try:
            url = "https://news.google.com/rss/search?q=ekonomi+OR+borsa+OR+piyasa+OR+döviz+OR+hisse+when:1d&hl=tr&gl=TR&ceid=TR:tr"
            res = requests.get(url, timeout=10)
            if res.status_code == 200:
                root_xml = ET.fromstring(res.content)
                for item in root_xml.findall('./channel/item')[:15]:
                    baslik = item.find('title').text
                    if " - " in baslik: baslik = baslik.rsplit(" - ", 1)[0]
                    yeni_haberler.append({
