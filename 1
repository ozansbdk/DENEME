def robo_danisman_analizi_baslat():
    if not kullanici_portfoyu:
        messagebox.showinfo("Uyarı", "Analiz edilecek portföy bulunamadı.")
        return
    if not finans_verileri:
        messagebox.showinfo("Uyarı", "Canlı veriler henüz yüklenmedi, lütfen bekleyin.")
        return
        
    robo_textbox.configure(state="normal")
    robo_textbox.delete("0.0", "end")
    robo_textbox.insert("0.0", "🤖 Robo-Danışman (AI) portföy riskinizi ve piyasa haberlerini analiz ediyor... Lütfen bekleyin.\n(Bu işlem ortalama 5-10 saniye sürebilir)")
    robo_textbox.configure(state="disabled")
    
    def ai_portfoy_thread():
        # Portföyü AI'a anlatacak formata çevir
        portfoy_ozeti = []
        for v in kullanici_portfoyu:
            s = v['sembol']
            if s in finans_verileri:
                guncel = finans_verileri[s]['deger']
                fark = ((guncel - v['maliyet']) / v['maliyet']) * 100
                portfoy_ozeti.append(f"- {s}: {v['miktar']} adet, Maliyet: {v['maliyet']}, Güncel: {guncel}, Kâr/Zarar: %{fark:.2f}")
        
        p_metin = "\n".join(portfoy_ozeti)
        h_metin = "\n".join([f"- {h['baslik']} ({h['etki']})" for h in haber_akisi_cache[:8]]) if haber_akisi_cache else "Yeni haber yok."
        
        prompt = f"""Sen dünyanın en iyi hedge fon yöneticisi ve yapay zeka tabanlı bir Robo-Danışmansın. 
Müşterinin güncel portföyü ve kâr/zarar durumu şu şekildedir:
{p_metin}

Piyasadaki son dakika haberleri ve etkileri şu şekildedir:
{h_metin}

Lütfen bu portföyü detaylı analiz et. 
1. Risk Dağılımı: Portföy çok mu riskli, çok mu defansif? (Çeşitlendirme iyi mi?)
2. Haberlerin Etkisi: Bugün çıkan haberler kullanıcının elindeki varlıkları (olumlu/olumsuz) nasıl etkiler?
3. Aksiyon Önerileri (Rebalancing): Portföyü daha güvenli veya kazançlı hale getirmek için hangi varlıktan kâr alıp hangisine geçmeli? Neleri tutmalı (Hold)?

Lütfen madde madde, finans jargonu kullanarak ama anlaşılır bir dille tavsiye ver. Uyarı: Bu bir yatırım tavsiyesi değildir ibaresini sona ekle."""

        sonuc = gemini_istek_gonder(prompt)
        
        def ui_guncelle():
            robo_textbox.configure(state="normal")
            robo_textbox.delete("0.0", "end")
            if sonuc:
                robo_textbox.insert("0.0", sonuc)
            else:
                robo_textbox.insert("0.0", "Robo-Danışman'a şu an ulaşılamıyor. Lütfen API bağlantınızı kontrol edin.")
            robo_textbox.configure(state="disabled")
            
        root.after(0, ui_guncelle)
        
    threading.Thread(target=ai_portfoy_thread, daemon=True).start()


# --- ALARM SİSTEMİ KONTROLÜ ---
def kontrol_et_alarmlar():
    tetiklenenler = []
    for alarm in aktif_alarmlar:
        anahtar = alarm["sembol"]
        if anahtar in finans_verileri:
            guncel_deger = finans_verileri[anahtar]["deger"]
            hedef_deger = float(alarm["deger"])
            kosul = alarm["kosul"]
            
            if (kosul == ">" and guncel_deger > hedef_deger) or (kosul == "<" and guncel_deger < hedef_deger):
                tetiklenenler.append(f"{anahtar} {kosul} {hedef_deger} gerçekleşti! (Güncel: {guncel_deger:.2f})")
    
    if tetiklenenler:
        mesaj = "\n".join(tetiklenenler)
        root.after(0, lambda: messagebox.showwarning("🔔 Eşik Değer Alarmı!", mesaj))

def simule_et_alarmlar():
    if not aktif_alarmlar:
        messagebox.showinfo("Bilgi", "Test edilecek alarm bulunmuyor. Lütfen önce bir alarm kurun.")
        return
    tetiklenenler = []
    for alarm in aktif_alarmlar:
        anahtar = alarm["sembol"]
        hedef_deger = float(alarm["deger"])
        kosul = alarm["kosul"]
        simule_edilen_deger = hedef_deger + 1.0 if kosul == ">" else hedef_deger - 1.0
        tetiklenenler.append(f"🧪 [TEST SİMÜLASYONU]\n{anahtar} varlığı {kosul} {hedef_deger} şartını sağladı!\n(Sanal Anlık Değer: {simule_edilen_deger:.2f})")
        
    if tetiklenenler:
        mesaj = "\n\n".join(tetiklenenler)
        root.after(0, lambda: messagebox.showwarning("🔔 ALARM TESTİ BAŞARILI!", mesaj))

