                        "ozet": f"Yayınlanma: {item.find('pubDate').text}",
                        "kaynak": item.find('source').text,
                        "etki": etki_belirle(baslik),
                        "url": item.find('link').text
                    })
        except: pass
        if not yeni_haberler:
            yeni_haberler = [{"baslik": "Piyasalar veri bekliyor", "ozet": "Demo Haber", "kaynak": "Demo", "etki": "Nötr", "url": ""}]
        haber_akisi_cache = yeni_haberler
