def ciz_korelasyon():
    s1 = corr_var1.get()
    s2 = corr_var2.get()
    
    if s1 not in gecmis_veriler or s2 not in gecmis_veriler:
        messagebox.showwarning("Hata", "Seçilen varlıklar için geçmiş veri bulunamadı.")
        return
        
    for w in corr_chart_frame.winfo_children(): w.destroy()
    
    fig, ax1 = plt.subplots(figsize=(10, 5), facecolor='#181b1f')
    fig.patch.set_facecolor('#181b1f')
    ax1.set_facecolor('#181b1f')
    
    d1 = gecmis_veriler[s1]
    d2 = gecmis_veriler[s2]
    
    min_len = min(len(d1["tarihler"]), len(d2["tarihler"]))
    tarihler = [datetime.datetime.strptime(t, '%Y-%m-%d') for t in d1["tarihler"][-min_len:]]
    
    c1, c2 = "#3498db", "#e74c3c"
    
    ax1.plot(tarihler, d1["degerler"][-min_len:], color=c1, label=s1, linewidth=2)
    ax1.set_ylabel(s1, color=c1)
    ax1.tick_params(axis='y', labelcolor=c1)
    
    ax2 = ax1.twinx()
    ax2.plot(tarihler, d2["degerler"][-min_len:], color=c2, label=s2, linewidth=2)
    ax2.set_ylabel(s2, color=c2)
    ax2.tick_params(axis='y', labelcolor=c2)
    
    ax1.xaxis.set_major_formatter(mdates.DateFormatter('%b %y'))
    fig.autofmt_xdate()
    
    for ax in [ax1, ax2]:
        ax.tick_params(colors='white')
        for spine in ax.spines.values(): spine.set_color('#3d3d3d')
    ax1.grid(color='#3d3d3d', linestyle='--', linewidth=0.5)
    
    plt.title(f"Korelasyon: {s1} vs {s2}", color="white")
    fig.legend(loc="upper left", bbox_to_anchor=(0.1,0.9), facecolor='#1e272e', edgecolor='none', labelcolor='white')
    
    plt.tight_layout()
    canvas = FigureCanvasTkAgg(fig, master=corr_chart_frame)
    canvas.draw()
    canvas.get_tk_widget().pack(fill="both", expand=True)

# --- ARAYÜZ OLUŞTURMA (DASHBOARD KARTLARI) ---
def create_card(parent, row, col, item, veri):
    card = ctk.CTkFrame(parent, fg_color="#1e272e", corner_radius=12, border_width=2, border_color="#2f3640")
    card.grid(row=row, column=col, padx=12, pady=12, sticky="nsew")
    
    def on_enter(e):
        card.configure(border_color=item["renk"], fg_color="#26313a")
        card.configure(cursor="hand2")

    def on_leave(e):
        card.configure(border_color="#2f3640", fg_color="#1e272e")
        card.configure(cursor="")

    def on_click(e):
        goster_detay_modal(item["anahtar"], item["baslik"], item["ikon"], item["renk"], veri["birim"])

    def on_right_click(e):
        cevap = messagebox.askyesno("Sembolü Sil", f"'{item['baslik']}' sembolünü takip listesinden kaldırmak istiyor musunuz?")
        if cevap:
            global dinamik_konfigurasyon
            dinamik_konfigurasyon = [x for x in dinamik_konfigurasyon if x["anahtar"] != item["anahtar"]]
            ayarlari_kaydet()
            guncelle_dropdown_listeleri()
            guncelle_arayuz()

    top_frame = ctk.CTkFrame(card, fg_color="transparent")
    top_frame.pack(fill="x", padx=15, pady=(15, 5))
    ctk.CTkLabel(top_frame, text=item["ikon"], font=("Segoe UI", 24), text_color=item["renk"]).pack(side="left")
    ctk.CTkLabel(top_frame, text=item["baslik"], font=("Segoe UI", 13, "bold"), text_color="#bdc3c7").pack(side="left", padx=10)
    
    mid_frame = ctk.CTkFrame(card, fg_color="transparent")
    mid_frame.pack(fill="x", padx=15, pady=0)
    
    format_string = "{:,.4f}" if "USD" in item["anahtar"].upper() else "{:,.2f}"
    val_str = format_string.format(float(veri["deger"]))
    
    ctk.CTkLabel(mid_frame, text=val_str, font=("Segoe UI", 28, "bold"), text_color="white").pack(side="left")
    ctk.CTkLabel(mid_frame, text=veri["birim"], font=("Segoe UI", 14), text_color="#95a5a6").pack(side="left", padx=5, pady=5)
    
    bot_frame = ctk.CTkFrame(card, fg_color="transparent")
    bot_frame.pack(fill="x", padx=15, pady=(0, 15))
    
    degisim = float(veri["degisim"])
    deg_color = "#2ecc71" if degisim >= 0 else "#e74c3c"
    deg_ok = "▲" if degisim >= 0 else "▼"
    if "Tüfe" in item["baslik"] or "Üfe" in item["baslik"] or "AOFM" in item["baslik"] or "Aktifhv" in item["baslik"]:
        deg_color = "#e74c3c" if degisim > 0 else "#2ecc71"
        
    ctk.CTkLabel(bot_frame, text=f"{deg_ok} {abs(degisim):.2f}%", font=("Segoe UI", 12, "bold"), text_color=deg_color).pack(side="left")
    
    for widget in [card, top_frame, mid_frame, bot_frame] + card.winfo_children() + top_frame.winfo_children() + mid_frame.winfo_children() + bot_frame.winfo_children():
        widget.bind("<Enter>", on_enter)
        widget.bind("<Leave>", on_leave)
        widget.bind("<Button-1>", on_click)
        widget.bind("<Button-3>", on_right_click)

def guncelle_arayuz():
    if not finans_verileri: return
        
    for widget in dashboard_icerik.winfo_children(): widget.destroy()
        
    for i in range(4): dashboard_icerik.grid_columnconfigure(i, weight=1)
        
